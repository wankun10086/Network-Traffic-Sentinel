{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "流量哨兵",
  "version": "0.1.0",
  "identifier": "com.local.traffic-sentinel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "流量哨兵",
        "width": 1180,
        "height": 760,
        "minWidth": 1080,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "widget",
        "title": "流量哨兵悬浮窗",
        "url": "index.html#/widget",
        "width": 286,
        "height": 186,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/geoip/country-ranges.csv"],
    "icon": ["icons/icon.ico"],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "本机网络流量监控",
    "longDescription": "监控本机网络流量、应用连接和中国大陆外流量。",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
